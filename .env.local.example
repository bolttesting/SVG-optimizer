# Canonical site URL (sitemap, Open Graph, JSON-LD, admin “live URL” preview for new posts)
NEXT_PUBLIC_SITE_URL=https://yoursite.com

# Optional: Plausible analytics — only loads if user accepts cookies in the banner
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=yoursite.com

# Optional: shown on /contact (mailto + “open in email app” form)
NEXT_PUBLIC_CONTACT_EMAIL=hello@yoursite.com
# Optional: GitHub repo link on /contact
NEXT_PUBLIC_CONTACT_GITHUB=https://github.com/yourname/svg-optimizer

# Supabase (blog, images, admin usage stats). Run 001_blog_and_storage.sql then 002_analytics_sessions.sql in the SQL editor.
# NEXT_PUBLIC_* are safe for the browser; keep SERVICE_ROLE secret (Vercel: server-only).
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Admin password: used to sign in at /admin/login (httpOnly session cookie, 7 days).
# Same value is used to sign the JWT — use a long random string; never commit the real value.
# Leading/trailing spaces in this value are trimmed when matching (helps Vercel paste mistakes).
ADMIN_SECRET=sedtfgwerotgiopweriopgiopdfjklgbadruiotgsdjigvjsratgweruioagubuiruea
