# Canonical site URL (sitemap, Open Graph, JSON-LD, admin “live URL” preview).
# Production domain: https://svgoptimizer.site — set on Hostinger / Vercel as below (omit only for previews).
NEXT_PUBLIC_SITE_URL=https://svgoptimizer.site

# Optional: X (Twitter) handle for /contact and blog metadata (e.g. @svgoptimizer)
# NEXT_PUBLIC_TWITTER_HANDLE=

# Optional: Plausible analytics — script is injected by ConditionalAnalytics (layout) when this is set
# AND the visitor accepts analytics in the cookie banner. Do not add a second <script> for Plausible in layout.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=svgoptimizer.site

# Contact email (mailto link, /contact page, footer). Defaults to info@svgoptimizer.site when unset.
# Set to empty on the host to hide: NEXT_PUBLIC_CONTACT_EMAIL=
# NEXT_PUBLIC_CONTACT_EMAIL=info@svgoptimizer.site
# Optional: GitHub repo link on /contact
# NEXT_PUBLIC_CONTACT_GITHUB=https://github.com/bolttesting/SVG-optimizer

# Production (npm start / Hostinger Node): TCP bind address. Default 0.0.0.0.
# Hostinger + LiteSpeed: if you see recurring 503, set BOTH and restart the app:
# PORT=3000
# LISTEN_HOST=127.0.0.1
# Do not set HOST to your domain for binding—the start script ignores HOST on purpose.

# --- Optional: “Send message” on /contact (server SMTP). Hostinger example: smtp.hostinger.com:465 SSL ---
# SMTP_HOST=smtp.hostinger.com
# SMTP_PORT=465
# SMTP_USER=info@svgoptimizer.site
# SMTP_PASS=your-mailbox-password
# Optional: inbox if different from SMTP_USER (defaults to contact email / info@)
# CONTACT_SMTP_TO=info@svgoptimizer.site

# Supabase (blog, images, admin usage stats). Run 001_blog_and_storage.sql then 002_analytics_sessions.sql in the SQL editor.
# NEXT_PUBLIC_* are safe for the browser; keep SERVICE_ROLE secret (Vercel: server-only).
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Admin password: used to sign in at /admin/login (httpOnly session cookie, 7 days).
# Same value is used to sign the JWT — use a long random string; never commit the real value.
# Leading/trailing spaces in this value are trimmed when matching (helps Vercel paste mistakes).
ADMIN_SECRET=sedtfgwerotgiopweriopgiopdfjklgbadruiotgsdjigvjsratgweruioagubuiruea
